OPENAI_API_KEY=your-openai-api-key

# n8n support ticket agent workflow
N8N_SUPPORT_TICKET_WEBHOOK_URL=
N8N_SUPPORT_TICKET_WEBHOOK_SECRET=
N8N_SUPPORT_TICKET_TIMEOUT_SECONDS=20

# Backend hosting
PORT=8000
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://qualitative-ai-studio.onrender.com
STORAGE_BACKEND=supabase
LOCAL_STORAGE_ROOT=backend_data

# Supabase-backed storage/auth
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Local cookie settings
AUTH_ACCESS_COOKIE_NAME=qa_access_token
AUTH_REFRESH_COOKIE_NAME=qa_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Security hardening
MAX_UPLOAD_BYTES=5242880
ALLOWED_UPLOAD_EXTENSIONS=.txt,.md,.pdf,.docx
AUTH_RATE_LIMIT_ATTEMPTS=8
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
